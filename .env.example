# =============================================
# AssetIQ — Environment Variables
# Copy this file to .env and fill in your values
# NEVER share or commit the .env file
# =============================================

# --- DATABASE (from Neon dashboard) ---
# Go to neon.tech → your project → Connection string
DATABASE_URL="postgresql://username:password@host/assetiq?sslmode=require"

# --- AUTH SECRET (generate one yourself) ---
# Open any browser, go to: https://generate-secret.vercel.app/32
# Copy the result and paste here
AUTH_SECRET="paste-a-random-secret-here"

# --- NEXTAUTH URL ---
# For local development use the line below
# For production, change to your Vercel URL (e.g. https://assetiq.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# --- MICROSOFT LOGIN (optional for now, add later) ---
# Leave these blank until you have Azure set up
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# --- OPENAI (from platform.openai.com → API keys) ---
# Free tier: uses gpt-3.5-turbo
# Paid tier: uses gpt-4o (app detects automatically)
OPENAI_API_KEY="sk-..."

# --- CLOUDINARY (from cloudinary.com dashboard) ---
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# --- EMAIL (for sending expiry alerts) ---
# Option 1: Gmail — use your Gmail + an App Password
# Go to: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="AssetIQ Alerts <your@gmail.com>"

# --- APP CONFIG ---
APP_URL="http://localhost:3000"
COMPANY_NAME="Xeltr"
APP_NAME="AssetIQ"
